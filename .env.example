# SMTP Configuration for Email Service
# These environment variables are required for the email contact forms to work

# SMTP Server Host (e.g., smtp.gmail.com, smtp.sendgrid.net, etc.)
SMTP_HOST=your_smtp_host

# SMTP Server Port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# SMTP Security - set to 'true' for port 465 (SSL), 'false' for port 587 (TLS)
SMTP_SECURE=false

# SMTP Authentication Username
SMTP_USER=your_smtp_username

# SMTP Authentication Password (or API key for services like SendGrid)
SMTP_PASS=your_smtp_password

# Sender Email Address (the "from" address in emails)
SMTP_FROM=noreply@rankfest.co

# Recipient Email Address (where form submissions are sent)
SMTP_TO=info@rankfest.co
